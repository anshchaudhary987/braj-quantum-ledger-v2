# =============================================================================
# GLM — Git Ignore
# =============================================================================

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# Build output
dist/
build/
*.tsbuildinfo

# Environment files (NEVER commit secrets)
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production
.env.backup

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Testing
coverage/
*.lcov

# Logs
logs/
*.log

# Temporary files
tmp/
temp/
*.tmp

.vercel
