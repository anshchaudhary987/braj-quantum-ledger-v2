{
  "name": "glm-ledger",
  "version": "1.0.0",
  "description": "GLM - Next-Gen Indian Accounting SaaS (Double-Entry, GST-Compliant, Multi-Tenant)",
  "main": "dist/api/server.js",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/api/server.js",
    "dev": "tsx watch src/api/server.ts",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "typecheck": "tsc --noEmit",
    "db:migrate": "node --loader tsx scripts/run-migrations.ts",
    "db:seed": "node --loader tsx scripts/run-seeds.ts",
    "test": "NODE_ENV=test vitest",
    "test:unit": "NODE_ENV=test vitest --run src/",
    "test:integration": "NODE_ENV=test vitest --run tests/integration/",
    "security:audit": "npm audit",
    "clean": "rm -rf dist/",
    "postinstall": "npm run build"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "bcrypt": "^6.0.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "node-pg-migrate": "^6.2.2",
    "pg": "^8.11.3",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1",
    "sax": "^1.6.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.10.5",
    "@types/pg": "^8.10.9",
    "@types/sax": "^1.2.7",
    "@types/supertest": "^6.0.2",
    "@types/three": "^0.184.1",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "eslint": "^8.56.0",
    "pg-mem": "^2.8.0",
    "supertest": "^6.3.3",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.5"
  },
  "keywords": [
    "accounting",
    "gst",
    "india",
    "ledger",
    "double-entry",
    "saas",
    "multi-tenant",
    "e-invoicing"
  ],
  "author": "GLM Engineering <dev@glm-saas.in>",
  "license": "UNLICENSED",
  "private": true
}
